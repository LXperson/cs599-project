# DeepSeek API 配置（或其他兼容 OpenAI 协议的 API）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 可选：LangSmith 可观测性
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=cs599-project

# LLM 调用参数
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
LLM_RETRIES=3
LLM_REQUEST_TIMEOUT=120

# 审查参数
MAX_FILE_SIZE_KB=500
MAX_DIR_FILES=10

# Agent 参数
MAX_RECURSION=15
MAX_MEMORY_TOKENS=8000

# 记忆参数
MEMORY_MAX_TURNS=30
MEMORY_MAX_FILE_OPS=50
